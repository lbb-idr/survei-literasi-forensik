{
  "manifest_version": 3,
  "name": "GForm Creator",
  "version": "1.0",
  "description": "Buat Google Form otomatis dari output JSON Gemini/LLM — jembatan antara AI dan Google Forms",
  "permissions": [
    "storage",
    "clipboardRead"
  ],
  "host_permissions": [
    "https://script.google.com/macros/s/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
